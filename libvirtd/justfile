# Pending nfs-utils packaging rework
# Fixed in Fedora 44
pre_commands := "dnf remove -y nfs-utils-coreos"

import '../sysext.just'

all: default

install-manual:
    #!/bin/bash
    set -euo pipefail
    if [[ -n "{{debug}}" ]]; then
      set -x
    fi

    if [[ "${UID}" == "0" ]]; then
        SUDO=""
    else
        SUDO="sudo"
    fi

    cd rootfs

    # Fixup netcat/nc as we don't run the alternatives command from scriplets
    ${SUDO} ln -snf netcat usr/bin/nc

    # Move extlinux to /usr/bin as needed
    if [[ -f sbin/extlinux ]]; then
        ${SUDO} mv sbin/extlinux usr/bin/extlinux
        ${SUDO} rmdir sbin
    fi

    # Make libiscsi libs visible by the linker
    # libisci add a config drop-in to the linker under /etc
    # See https://src.fedoraproject.org/rpms/libiscsi/blob/rawhide/f/libiscsi.spec#_39
    # Ideally the linker would source configs from /usr as well
    ${SUDO} mkdir -p ./usr/lib/ld.so.conf.d/
    ${SUDO} mv ./etc/ld.so.conf.d/* ./usr/lib/ld.so.conf.d

    # Empty out /var & /boot
    ${SUDO} rm -rf ./var ./boot
